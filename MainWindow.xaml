<Window x:Class="ServerLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Server Launcher"
        Width="1120"
        Height="720"
        MinWidth="940"
        MinHeight="620"
        Background="#F4F7F5">
  <Window.Resources>
    <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
      <Setter Property="Background" Value="#E6EFEA"/>
      <Setter Property="Foreground" Value="#17201B"/>
    </Style>
    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="26"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
      <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>
    <Style x:Key="LabelStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
      <Setter Property="Margin" Value="0,12,0,4"/>
    </Style>
  </Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="230"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <Border Grid.Column="0" Background="#FFFFFF" BorderBrush="#D9E2DD" BorderThickness="0,0,1,0">
      <DockPanel Margin="18">
        <StackPanel DockPanel.Dock="Top">
          <TextBlock Text="Minecraft" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
          <TextBlock Text="Server Launcher" Foreground="{StaticResource MutedBrush}" Margin="0,2,0,24"/>

          <Button x:Name="HomeNavButton" Content="Главная" Style="{StaticResource NavButtonStyle}" Click="HomeNavButton_Click"/>
          <Button x:Name="NewsNavButton" Content="Новости" Style="{StaticResource NavButtonStyle}" Click="NewsNavButton_Click"/>
          <Button x:Name="ModsNavButton" Content="Моды" Style="{StaticResource NavButtonStyle}" Click="ModsNavButton_Click"/>
          <Button x:Name="MapNavButton" Content="Карта" Style="{StaticResource NavButtonStyle}" Click="MapNavButton_Click"/>
          <Button x:Name="SettingsNavButton" Content="Настройки" Style="{StaticResource NavButtonStyle}" Click="SettingsNavButton_Click"/>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom">
          <TextBlock Text="Статус" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,4"/>
          <TextBlock x:Name="SidebarStatusText" Text="Загрузка..." TextWrapping="Wrap" Foreground="{StaticResource TextBrush}"/>
        </StackPanel>
      </DockPanel>
    </Border>

    <Grid Grid.Column="1" Margin="28">
      <Grid.RowDefinitions>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <Grid x:Name="HomePanel">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel>
          <TextBlock x:Name="ServerNameText" Text="Minecraft Server" FontSize="36" FontWeight="Bold" Foreground="{StaticResource TextBrush}"/>
          <TextBlock x:Name="ServerVersionText" Text="Manifest не загружен" FontSize="15" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,18"/>
          <TextBlock x:Name="MainStatusText" Text="Укажите ссылку на manifest.json в настройках." FontSize="17" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,26,0,24">
          <Button x:Name="PlayButton" Content="Играть" MinWidth="140" Click="PlayButton_Click"/>
          <Button x:Name="RepairButton" Content="Проверить файлы" Background="#FFFFFF" Foreground="{StaticResource TextBrush}" BorderBrush="#C8D4CE" BorderThickness="1" Click="RepairButton_Click"/>
          <Button x:Name="RefreshManifestButton" Content="Обновить manifest" Background="#FFFFFF" Foreground="{StaticResource TextBrush}" BorderBrush="#C8D4CE" BorderThickness="1" Click="RefreshManifestButton_Click"/>
        </StackPanel>

        <Grid Grid.Row="2">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <Border Background="{StaticResource SurfaceBrush}" BorderBrush="#D9E2DD" BorderThickness="1" Padding="18" Margin="0,0,10,0">
            <StackPanel>
              <TextBlock Text="Сборка" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
              <TextBlock x:Name="PackInfoText" Text="Ожидает manifest" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0" TextWrapping="Wrap"/>
              <TextBlock x:Name="LoaderInfoText" Text="" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
              <TextBlock x:Name="InstallInfoText" Text="" Foreground="{StaticResource MutedBrush}" Margin="0,6,0,0" TextWrapping="Wrap"/>
            </StackPanel>
          </Border>

          <Border Grid.Column="1" Background="{StaticResource SurfaceBrush}" BorderBrush="#D9E2DD" BorderThickness="1" Padding="18" Margin="10,0,0,0">
            <StackPanel>
              <TextBlock Text="Последние изменения" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}"/>
              <ItemsControl x:Name="HomeChangelogList" Margin="0,8,0,0"/>
            </StackPanel>
          </Border>
        </Grid>
      </Grid>

      <Grid x:Name="NewsPanel" Visibility="Collapsed">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Новости" Style="{StaticResource SectionTitleStyle}"/>
        <ListBox x:Name="NewsList" Grid.Row="1" BorderBrush="#D9E2DD"/>
      </Grid>

      <Grid x:Name="ModsPanel" Visibility="Collapsed">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Моды и файлы сборки" Style="{StaticResource SectionTitleStyle}"/>
        <ListView x:Name="FilesList" Grid.Row="1" BorderBrush="#D9E2DD">
          <ListView.View>
            <GridView>
              <GridViewColumn Header="Путь" DisplayMemberBinding="{Binding Path}" Width="360"/>
              <GridViewColumn Header="Категория" DisplayMemberBinding="{Binding Category}" Width="120"/>
              <GridViewColumn Header="Обязательный" DisplayMemberBinding="{Binding Required}" Width="120"/>
              <GridViewColumn Header="Размер" DisplayMemberBinding="{Binding Size}" Width="110"/>
              <GridViewColumn Header="Статус" DisplayMemberBinding="{Binding Status}" Width="160"/>
            </GridView>
          </ListView.View>
        </ListView>
      </Grid>

      <Grid x:Name="MapPanel" Visibility="Collapsed">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel Margin="0,0,0,12">
          <TextBlock Text="Карта" Style="{StaticResource SectionTitleStyle}" DockPanel.Dock="Left"/>
          <Button x:Name="OpenMapButton" Content="Открыть карту в браузере" DockPanel.Dock="Right" HorizontalAlignment="Right" Click="OpenMapButton_Click"/>
        </DockPanel>
        <Border Grid.Row="1" BorderBrush="#D9E2DD" BorderThickness="1" Background="White">
          <WebBrowser x:Name="MapBrowser"/>
        </Border>
      </Grid>

      <ScrollViewer x:Name="SettingsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="760">
          <TextBlock Text="Настройки" Style="{StaticResource SectionTitleStyle}"/>

          <TextBlock Text="Ссылка на manifest.json" Style="{StaticResource LabelStyle}"/>
          <TextBox x:Name="ManifestUrlBox"/>

          <TextBlock Text="Папка установки игры и сборки" Style="{StaticResource LabelStyle}"/>
          <DockPanel>
            <Button Content="Выбрать" DockPanel.Dock="Right" Margin="8,0,0,0" Click="BrowseInstallDirectoryButton_Click"/>
            <TextBox x:Name="InstallDirectoryBox"/>
          </DockPanel>

          <CheckBox x:Name="ShadersCheckBox" Content="Шейдеры" Margin="0,18,0,0"/>

          <TextBlock Text="RAM, МБ" Style="{StaticResource LabelStyle}"/>
          <TextBox x:Name="RamBox"/>

          <TextBlock Text="Имя игрока" Style="{StaticResource LabelStyle}"/>
          <TextBox x:Name="PlayerNameBox"/>

          <TextBlock Text="Путь к java.exe" Style="{StaticResource LabelStyle}"/>
          <DockPanel>
            <Button Content="Выбрать" DockPanel.Dock="Right" Margin="8,0,0,0" Click="BrowseJavaButton_Click"/>
            <TextBox x:Name="JavaPathBox"/>
          </DockPanel>

          <TextBlock Text="Дополнительные аргументы запуска" Style="{StaticResource LabelStyle}"/>
          <TextBox x:Name="ExtraArgsBox"/>

          <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
            <Button Content="Сохранить" Click="SaveSettingsButton_Click"/>
            <Button Content="Открыть папку игры" Background="#FFFFFF" Foreground="{StaticResource TextBrush}" BorderBrush="#C8D4CE" BorderThickness="1" Click="OpenInstallDirectoryButton_Click"/>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>

      <StackPanel Grid.Row="1" Margin="0,18,0,0">
        <ProgressBar x:Name="ProgressBar" Height="8" IsIndeterminate="False"/>
        <TextBlock x:Name="ProgressText" Text="" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0"/>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
