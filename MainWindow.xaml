<Window x:Class="ServerLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="minivibe"
        Icon="Assets/launcher-icon.ico"
        Width="1180"
        Height="760"
        MinWidth="980"
        MinHeight="640"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType"
        TextOptions.TextHintingMode="Fixed"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
  <Window.Resources>
    <Style TargetType="Button">
      <Setter Property="MinHeight" Value="38"/>
      <Setter Property="Padding" Value="16,8"/>
      <Setter Property="Margin" Value="0,0,8,0"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonRoot"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.88"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="ButtonRoot" Property="RenderTransform">
                  <Setter.Value>
                    <ScaleTransform ScaleX="0.98" ScaleY="0.98"/>
                  </Setter.Value>
                </Setter>
                <Setter TargetName="ButtonRoot" Property="RenderTransformOrigin" Value="0.5,0.5"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="ButtonRoot" Property="Opacity" Value="0.45"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>

    <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="HorizontalContentAlignment" Value="Left"/>
      <Setter Property="Margin" Value="0,0,0,8"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{DynamicResource MutedBrush}"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="14,10"/>
    </Style>

    <Style x:Key="CardStyle" TargetType="Border">
      <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="Padding" Value="18"/>
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="26"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
      <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>

    <Style x:Key="LabelStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource MutedBrush}"/>
      <Setter Property="Margin" Value="0,12,0,5"/>
    </Style>

    <Style TargetType="TextBox">
      <Setter Property="MinHeight" Value="36"/>
      <Setter Property="Padding" Value="10,7"/>
      <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CaretBrush" Value="{DynamicResource AccentBrush}"/>
    </Style>

    <Style TargetType="ComboBox">
      <Setter Property="MinHeight" Value="36"/>
      <Setter Property="Padding" Value="8,5"/>
      <Setter Property="Background" Value="{DynamicResource SurfaceAltBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>

    <Style TargetType="ComboBoxItem">
      <Setter Property="MinHeight" Value="32"/>
      <Setter Property="Padding" Value="10,7"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="Background" Value="{DynamicResource ComboItemBackgroundBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource ComboItemTextBrush}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBoxItem">
            <Border x:Name="ItemRoot"
                    Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsHighlighted" Value="True">
                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource AccentBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="ItemRoot" Property="Background" Value="{DynamicResource AccentBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style TargetType="CheckBox">
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
      <Setter Property="Margin" Value="0,14,0,0"/>
    </Style>

    <Style TargetType="ListBox">
      <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>

    <Style TargetType="ListView">
      <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>
  </Window.Resources>

  <Grid x:Name="MainRoot" Background="{DynamicResource AppBackgroundBrush}">
    <Grid x:Name="DynamicLayer" IsHitTestVisible="False" ClipToBounds="True">
      <Rectangle Fill="{DynamicResource AtmosphereBrush}" Opacity="0.55"/>
      <Rectangle x:Name="SignalLine"
                 Width="420"
                 Height="2"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="0,86,0,0"
                 Opacity="0.9">
        <Rectangle.Fill>
          <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#00FFFFFF" Offset="0"/>
            <GradientStop Color="#AAFFFFFF" Offset="0.5"/>
            <GradientStop Color="#00FFFFFF" Offset="1"/>
          </LinearGradientBrush>
        </Rectangle.Fill>
        <Rectangle.RenderTransform>
          <TranslateTransform X="-460"/>
        </Rectangle.RenderTransform>
        <Rectangle.Triggers>
          <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard>
              <Storyboard RepeatBehavior="Forever">
                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)"
                                 From="-460"
                                 To="1400"
                                 Duration="0:0:7"/>
                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                 From="0.25"
                                 To="0.95"
                                 AutoReverse="True"
                                 Duration="0:0:2.8"/>
              </Storyboard>
            </BeginStoryboard>
          </EventTrigger>
        </Rectangle.Triggers>
      </Rectangle>
    </Grid>

    <Grid Margin="22">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="250"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              Background="{DynamicResource SidebarBrush}"
              BorderBrush="{DynamicResource BorderBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="18">
        <DockPanel>
          <StackPanel DockPanel.Dock="Top">
            <TextBlock Text="minivibe" FontSize="27" FontWeight="Black" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap"/>

            <Button x:Name="HomeNavButton" Content="Главная" Style="{StaticResource NavButtonStyle}" Click="HomeNavButton_Click"/>
            <Button x:Name="NewsNavButton" Content="Новости" Style="{StaticResource NavButtonStyle}" Click="NewsNavButton_Click"/>
            <Button x:Name="MapNavButton" Content="Карта" Style="{StaticResource NavButtonStyle}" Click="MapNavButton_Click"/>
            <Button x:Name="SkinsNavButton" Content="Скины" Style="{StaticResource NavButtonStyle}" Click="SkinsNavButton_Click"/>
            <Button x:Name="SettingsNavButton" Content="Настройки" Style="{StaticResource NavButtonStyle}" Click="SettingsNavButton_Click"/>
          </StackPanel>

          <StackPanel DockPanel.Dock="Bottom">
            <Border Background="{DynamicResource SurfaceAltBrush}" CornerRadius="8" Padding="12">
              <StackPanel>
                <TextBlock Text="Статус" Foreground="{DynamicResource MutedBrush}" FontSize="12"/>
                <TextBlock x:Name="SidebarStatusText" Text="Загрузка..." TextWrapping="Wrap" Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold" Margin="0,4,0,0"/>
              </StackPanel>
            </Border>
          </StackPanel>
        </DockPanel>
      </Border>

      <Grid x:Name="ContentShell" Grid.Column="1" Margin="26,0,0,0">
        <Grid.RowDefinitions>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid x:Name="HomePanel">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>

          <Border Style="{StaticResource CardStyle}" Padding="24">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
              </Grid.ColumnDefinitions>

              <StackPanel>
                <TextBlock x:Name="ServerNameText" Text="minivibe" FontSize="42" FontWeight="Black" Foreground="{DynamicResource TextBrush}"/>
                <TextBlock x:Name="ServerVersionText" Text="Manifest не загружен" FontSize="15" Foreground="{DynamicResource MutedBrush}" Margin="0,6,0,18"/>
                <TextBlock x:Name="MainStatusText" Text="Проверяю сборку..." FontSize="17" Foreground="{DynamicResource TextBrush}" TextWrapping="Wrap" MaxWidth="640"/>

                <StackPanel Orientation="Horizontal" Margin="0,26,0,0">
                  <Button x:Name="PlayButton" Content="Установить" MinWidth="150" Click="PlayButton_Click"/>
                  <Button x:Name="RepairButton" Content="Проверить файлы" Style="{StaticResource SecondaryButtonStyle}" Click="RepairButton_Click"/>
                  <Button x:Name="RefreshManifestButton" Content="Обновить список" Style="{StaticResource SecondaryButtonStyle}" Click="RefreshManifestButton_Click"/>
                </StackPanel>
              </StackPanel>

              <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="Профиль" Foreground="{DynamicResource MutedBrush}" FontSize="12"/>
                <DockPanel x:Name="HomeNameInputPanel" Margin="0,5,0,6">
                  <Button x:Name="ConfirmPlayerNameButton"
                          Content="Подтвердить"
                          DockPanel.Dock="Right"
                          Margin="8,0,0,0"
                          MinWidth="112"
                          Click="ConfirmPlayerNameButton_Click"/>
                  <TextBox x:Name="HomePlayerNameBox" TextChanged="PlayerNameBox_TextChanged"/>
                </DockPanel>
                <Border x:Name="HomeNameLockedPanel"
                        Visibility="Collapsed"
                        Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="12"
                        Margin="0,5,0,6">
                  <TextBlock x:Name="LockedPlayerNameText"
                             FontSize="18"
                             FontWeight="SemiBold"
                             Foreground="{DynamicResource TextBrush}"
                             TextWrapping="Wrap"/>
                </Border>
                <TextBlock x:Name="PlayerPreviewText" Text="Ник появится в игре" FontSize="12" Foreground="{DynamicResource MutedBrush}" TextWrapping="Wrap" Margin="0,0,0,14"/>
                <TextBlock Text="Сборка" Foreground="{DynamicResource MutedBrush}" FontSize="12"/>
                <TextBlock x:Name="PackPreviewText" Text="ожидает manifest" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,2,0,14"/>
                <TextBlock Text="Loader" Foreground="{DynamicResource MutedBrush}" FontSize="12"/>
                <TextBlock x:Name="LoaderPreviewText" Text="NeoForge" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,2,0,14"/>
                <TextBlock Text="Лаунчер" Foreground="{DynamicResource MutedBrush}" FontSize="12"/>
                <TextBlock x:Name="LauncherPreviewText" Text="0.0.0" FontSize="18" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,2,0,0"/>
              </StackPanel>
            </Grid>
          </Border>

          <Grid Grid.Row="1" Margin="0,18,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.05*"/>
              <ColumnDefinition Width="0.95*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,9,0">
              <StackPanel>
                <TextBlock Text="Сборка" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                <TextBlock x:Name="PackInfoText" Text="Ожидает manifest" Foreground="{DynamicResource MutedBrush}" Margin="0,10,0,0" TextWrapping="Wrap"/>
                <TextBlock x:Name="LoaderInfoText" Text="" Foreground="{DynamicResource MutedBrush}" Margin="0,7,0,0" TextWrapping="Wrap"/>
                <TextBlock x:Name="InstallInfoText" Text="" Foreground="{DynamicResource MutedBrush}" Margin="0,7,0,0" TextWrapping="Wrap"/>
              </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="9,0,0,0">
              <StackPanel>
                <TextBlock Text="Последние изменения" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}"/>
                <ItemsControl x:Name="HomeChangelogList" Margin="0,10,0,0"/>
              </StackPanel>
            </Border>
          </Grid>
        </Grid>

        <Grid x:Name="NewsPanel" Visibility="Collapsed">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <TextBlock Text="Новости" Style="{StaticResource SectionTitleStyle}"/>
          <ListBox x:Name="NewsList" Grid.Row="1"/>
        </Grid>

        <Grid x:Name="MapPanel" Visibility="Collapsed">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <DockPanel Margin="0,0,0,14">
            <TextBlock Text="Карта" Style="{StaticResource SectionTitleStyle}" DockPanel.Dock="Left"/>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
              <Button x:Name="ReloadMapButton" Content="Обновить" Style="{StaticResource SecondaryButtonStyle}" Click="ReloadMapButton_Click"/>
              <Button x:Name="OpenMapButton" Content="В браузере" HorizontalAlignment="Right" Click="OpenMapButton_Click"/>
            </StackPanel>
          </DockPanel>
          <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
              </Grid.RowDefinitions>
              <Grid ClipToBounds="True">
                <wv2:WebView2 x:Name="MapWebView"
                              DefaultBackgroundColor="#090A0F"/>
                <Border x:Name="MapFallbackPanel"
                        Background="{DynamicResource SurfaceAltBrush}"
                        CornerRadius="8"
                        Padding="22">
                  <StackPanel VerticalAlignment="Center" MaxWidth="620">
                    <TextBlock Text="3D-карта загружается"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextBrush}"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="MapStatusText"
                               Text="BlueMap будет открыта внутри лаунчера."
                               Foreground="{DynamicResource MutedBrush}"
                               Margin="0,10,0,0"
                               TextWrapping="Wrap"/>
                  </StackPanel>
                </Border>
              </Grid>
              <TextBlock x:Name="MapUrlText"
                         Grid.Row="1"
                         Foreground="{DynamicResource MutedBrush}"
                         Margin="0,12,0,0"
                         TextWrapping="Wrap"/>
            </Grid>
          </Border>
        </Grid>

        <Grid x:Name="SkinsPanel" Visibility="Collapsed">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
          </Grid.RowDefinitions>
          <DockPanel Margin="0,0,0,14">
            <TextBlock Text="Скины" Style="{StaticResource SectionTitleStyle}" DockPanel.Dock="Left"/>
            <TextBlock Text="PNG/JPG 64x64"
                       DockPanel.Dock="Right"
                       Foreground="{DynamicResource MutedBrush}"
                       VerticalAlignment="Center"
                       TextWrapping="Wrap"/>
          </DockPanel>
          <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="1.05*"/>
              <ColumnDefinition Width="0.95*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,9,0">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="*"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Background="{DynamicResource SurfaceAltBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        MinHeight="390"
                        ClipToBounds="True">
                  <wv2:WebView2 x:Name="SkinPreviewWebView"
                                DefaultBackgroundColor="#0B0D14"/>
                </Border>
                <StackPanel Grid.Row="1" Margin="0,14,0,0">
                  <TextBlock x:Name="SkinStatusText"
                             Text="Скин не выбран"
                             Foreground="{DynamicResource MutedBrush}"
                             TextWrapping="Wrap"/>
                  <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Content="Выбрать PNG" Click="ChooseSkinButton_Click"/>
                    <Button Content="Установить скин" Style="{StaticResource SecondaryButtonStyle}" Click="InstallSkinButton_Click"/>
                  </StackPanel>
                </StackPanel>
              </Grid>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="9,0,0,0">
              <StackPanel>
                <TextBlock Text="Общий сервер скинов" FontSize="18" FontWeight="SemiBold"/>
                <TextBlock Text="Формат: skins/Ник.png"
                           Foreground="{DynamicResource MutedBrush}"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"/>
                <TextBlock Text="Базовый URL" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="SkinServerUrlBox" TextChanged="SkinServerSetting_Changed"/>
                <CheckBox x:Name="EnableSkinServerCheckBox"
                          Content="Включить загрузку скинов по никам"
                          Click="SkinServerSetting_Changed"/>
                <TextBlock x:Name="SkinServerPreviewText"
                           Foreground="{DynamicResource MutedBrush}"
                           Margin="0,12,0,0"
                           TextWrapping="Wrap"/>
                <Button Content="Сохранить настройку"
                        Margin="0,16,0,0"
                        Click="SaveSkinServerButton_Click"/>

                <Border Height="1"
                        Background="{DynamicResource BorderBrush}"
                        Margin="0,18,0,16"/>
                <TextBlock Text="Загрузка скина"
                           FontSize="18"
                           FontWeight="SemiBold"/>
                <TextBlock Text="Скин уйдет в общий каталог skins/Ник.png"
                           Foreground="{DynamicResource MutedBrush}"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"/>
                <Button Content="Загрузить для всех"
                        Margin="0,16,0,0"
                        Click="UploadSharedSkinButton_Click"/>
              </StackPanel>
            </Border>
          </Grid>
        </Grid>

        <ScrollViewer x:Name="SettingsPanel" Visibility="Collapsed" VerticalScrollBarVisibility="Auto">
          <StackPanel MaxWidth="820">
            <TextBlock Text="Настройки" Style="{StaticResource SectionTitleStyle}"/>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
              <StackPanel>
                <TextBlock Text="Сборка" FontSize="18" FontWeight="SemiBold"/>

                <TextBlock Text="Папка установки игры и сборки" Style="{StaticResource LabelStyle}"/>
                <DockPanel>
                  <Button Content="Выбрать" DockPanel.Dock="Right" Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Click="BrowseInstallDirectoryButton_Click"/>
                  <TextBox x:Name="InstallDirectoryBox"/>
                </DockPanel>

                <CheckBox x:Name="ShadersCheckBox" Content="Шейдеры"/>

                <TextBlock Text="RAM, МБ" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="RamBox"/>

                <TextBlock Text="Имя игрока" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="PlayerNameBox" TextChanged="PlayerNameBox_TextChanged"/>

                <TextBlock Text="Дополнительные аргументы запуска" Style="{StaticResource LabelStyle}"/>
                <TextBox x:Name="ExtraArgsBox"/>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,14">
              <StackPanel>
                <TextBlock Text="Обновления" FontSize="18" FontWeight="SemiBold"/>

                <CheckBox x:Name="AutoUpdateCheckBox" Content="Автообновление лаунчера при запуске"/>
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock Text="Визуал" FontSize="18" FontWeight="SemiBold"/>

                <TextBlock Text="Цвета HEX" Style="{StaticResource LabelStyle}"/>
                <UniformGrid Columns="2" Margin="0,0,0,4">
                  <StackPanel Margin="0,0,6,6">
                    <TextBlock Text="Фон" Foreground="{DynamicResource MutedBrush}" FontSize="12"/>
                    <DockPanel>
                      <Button Content="Палитра" Tag="CustomBackgroundColorBox" DockPanel.Dock="Right" Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Click="ChooseColorButton_Click"/>
                      <TextBox x:Name="CustomBackgroundColorBox" ToolTip="#090A0F" TextChanged="VisualSetting_Changed"/>
                    </DockPanel>
                  </StackPanel>
                  <StackPanel Margin="6,0,0,6">
                    <TextBlock Text="Боковая панель" Foreground="{DynamicResource MutedBrush}" FontSize="12"/>
                    <DockPanel>
                      <Button Content="Палитра" Tag="CustomSidebarColorBox" DockPanel.Dock="Right" Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Click="ChooseColorButton_Click"/>
                      <TextBox x:Name="CustomSidebarColorBox" ToolTip="#11131A" TextChanged="VisualSetting_Changed"/>
                    </DockPanel>
                  </StackPanel>
                  <StackPanel Margin="0,0,6,6">
                    <TextBlock Text="Панели" Foreground="{DynamicResource MutedBrush}" FontSize="12"/>
                    <DockPanel>
                      <Button Content="Палитра" Tag="CustomSurfaceColorBox" DockPanel.Dock="Right" Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Click="ChooseColorButton_Click"/>
                      <TextBox x:Name="CustomSurfaceColorBox" ToolTip="#1A1D27" TextChanged="VisualSetting_Changed"/>
                    </DockPanel>
                  </StackPanel>
                  <StackPanel Margin="6,0,0,6">
                    <TextBlock Text="Границы" Foreground="{DynamicResource MutedBrush}" FontSize="12"/>
                    <DockPanel>
                      <Button Content="Палитра" Tag="CustomBorderColorBox" DockPanel.Dock="Right" Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Click="ChooseColorButton_Click"/>
                      <TextBox x:Name="CustomBorderColorBox" ToolTip="#343A4C" TextChanged="VisualSetting_Changed"/>
                    </DockPanel>
                  </StackPanel>
                  <StackPanel Margin="0,0,6,6">
                    <TextBlock Text="Текст" Foreground="{DynamicResource MutedBrush}" FontSize="12"/>
                    <DockPanel>
                      <Button Content="Палитра" Tag="CustomTextColorBox" DockPanel.Dock="Right" Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Click="ChooseColorButton_Click"/>
                      <TextBox x:Name="CustomTextColorBox" ToolTip="#F5F7FA" TextChanged="VisualSetting_Changed"/>
                    </DockPanel>
                  </StackPanel>
                  <StackPanel Margin="6,0,0,6">
                    <TextBlock Text="Вторичный текст" Foreground="{DynamicResource MutedBrush}" FontSize="12"/>
                    <DockPanel>
                      <Button Content="Палитра" Tag="CustomMutedTextColorBox" DockPanel.Dock="Right" Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Click="ChooseColorButton_Click"/>
                      <TextBox x:Name="CustomMutedTextColorBox" ToolTip="#A8AFBD" TextChanged="VisualSetting_Changed"/>
                    </DockPanel>
                  </StackPanel>
                  <StackPanel Margin="0,0,6,0">
                    <TextBlock Text="Акцент" Foreground="{DynamicResource MutedBrush}" FontSize="12"/>
                    <DockPanel>
                      <Button Content="Палитра" Tag="CustomAccentColorBox" DockPanel.Dock="Right" Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Click="ChooseColorButton_Click"/>
                      <TextBox x:Name="CustomAccentColorBox" ToolTip="#D84C5B" TextChanged="VisualSetting_Changed"/>
                    </DockPanel>
                  </StackPanel>
                  <StackPanel Margin="6,0,0,0">
                    <TextBlock Text="Градиент 1" Foreground="{DynamicResource MutedBrush}" FontSize="12"/>
                    <DockPanel>
                      <Button Content="Палитра" Tag="CustomGradientStartColorBox" DockPanel.Dock="Right" Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Click="ChooseColorButton_Click"/>
                      <TextBox x:Name="CustomGradientStartColorBox" ToolTip="#3225A8" TextChanged="VisualSetting_Changed"/>
                    </DockPanel>
                  </StackPanel>
                  <StackPanel Margin="0,6,6,0">
                    <TextBlock Text="Градиент 2" Foreground="{DynamicResource MutedBrush}" FontSize="12"/>
                    <DockPanel>
                      <Button Content="Палитра" Tag="CustomGradientEndColorBox" DockPanel.Dock="Right" Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Click="ChooseColorButton_Click"/>
                      <TextBox x:Name="CustomGradientEndColorBox" ToolTip="#00A3FF" TextChanged="VisualSetting_Changed"/>
                    </DockPanel>
                  </StackPanel>
                </UniformGrid>

                <CheckBox x:Name="DynamicBackgroundCheckBox" Content="Градиент" Click="VisualSetting_Changed"/>

                <TextBlock Text="Плотность панелей" Style="{StaticResource LabelStyle}"/>
                <Slider x:Name="PanelOpacitySlider"
                        Minimum="0.72"
                        Maximum="1"
                        TickFrequency="0.04"
                        IsSnapToTickEnabled="True"
                        ValueChanged="VisualSetting_Changed"/>
              </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,18,0,0">
              <Button Content="Сохранить" Click="SaveSettingsButton_Click"/>
              <Button Content="Открыть папку игры" Style="{StaticResource SecondaryButtonStyle}" Click="OpenInstallDirectoryButton_Click"/>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="1" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,16,0,0">
          <StackPanel>
            <ProgressBar x:Name="ProgressBar" Height="7" IsIndeterminate="False" Background="{DynamicResource ProgressTrackBrush}" Foreground="{DynamicResource AccentBrush}"/>
            <TextBlock x:Name="ProgressText" Text="" Foreground="{DynamicResource MutedBrush}" Margin="0,8,0,0"/>
          </StackPanel>
        </Border>
      </Grid>
    </Grid>
  </Grid>
</Window>
