<Application x:Class="ServerLauncher.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <SolidColorBrush x:Key="AccentBrush" Color="#2E7D5B"/>
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#DFF3EA"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextBrush" Color="#17201B"/>
    <SolidColorBrush x:Key="MutedBrush" Color="#64736C"/>
    <Style TargetType="Button">
      <Setter Property="MinHeight" Value="36"/>
      <Setter Property="Padding" Value="14,7"/>
      <Setter Property="Margin" Value="0,0,8,0"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="MinHeight" Value="34"/>
      <Setter Property="Padding" Value="8,6"/>
      <Setter Property="BorderBrush" Value="#C8D4CE"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <Style TargetType="PasswordBox">
      <Setter Property="MinHeight" Value="34"/>
      <Setter Property="Padding" Value="8,6"/>
      <Setter Property="BorderBrush" Value="#C8D4CE"/>
      <Setter Property="BorderThickness" Value="1"/>
    </Style>
  </Application.Resources>
</Application>
