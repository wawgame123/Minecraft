<Window x:Class="ServerLauncher.GameLogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Консоль Minecraft"
        Icon="Assets/launcher-icon.ico"
        Width="920"
        Height="560"
        MinWidth="720"
        MinHeight="420"
        Background="#090A0F"
        Foreground="#F5F7FA"
        FontFamily="Segoe UI">
  <Window.Resources>
    <Style TargetType="Button">
      <Setter Property="MinHeight" Value="34"/>
      <Setter Property="Padding" Value="14,7"/>
      <Setter Property="Margin" Value="0,0,8,0"/>
      <Setter Property="Background" Value="#252936"/>
      <Setter Property="Foreground" Value="#F5F7FA"/>
      <Setter Property="BorderBrush" Value="#343A4C"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Cursor" Value="Hand"/>
    </Style>
  </Window.Resources>

  <Grid Margin="18">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <DockPanel Margin="0,0,0,12">
      <StackPanel>
        <TextBlock Text="Консоль Minecraft"
                   FontSize="24"
                   FontWeight="Bold"/>
        <TextBlock x:Name="StatusText"
                   Text="Ожидаю запуск процесса..."
                   Foreground="#A8AFBD"
                   Margin="0,4,0,0"/>
      </StackPanel>
      <StackPanel DockPanel.Dock="Right"
                  Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Center">
        <Button Content="Очистить" Click="ClearButton_Click"/>
        <Button Content="Скопировать" Click="CopyButton_Click"/>
        <Button Content="Скрыть" Click="HideButton_Click"/>
      </StackPanel>
    </DockPanel>

    <Border Grid.Row="1"
            Background="#05070C"
            BorderBrush="#343A4C"
            BorderThickness="1"
            CornerRadius="8">
      <TextBox x:Name="LogBox"
               IsReadOnly="True"
               AcceptsReturn="True"
               AcceptsTab="True"
               TextWrapping="NoWrap"
               VerticalScrollBarVisibility="Auto"
               HorizontalScrollBarVisibility="Auto"
               BorderThickness="0"
               Background="Transparent"
               Foreground="#DDE7F5"
               CaretBrush="#DDE7F5"
               FontFamily="Consolas"
               FontSize="13"
               Padding="12"/>
    </Border>

    <TextBlock Grid.Row="2"
               Text="Если окно закрыть во время работы игры, оно просто скроется, а логи продолжат собираться."
               Foreground="#A8AFBD"
               Margin="0,10,0,0"
               TextWrapping="Wrap"/>
  </Grid>
</Window>
